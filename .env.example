# GitHub personal access token — for real data collection
# Get one at: https://github.com/settings/tokens (no special permissions needed)
GITHUB_TOKEN=your_github_token_here

# DeepSeek API key — for LLM weak labeling (very cheap, ~$0.001/1K tokens)
# Get one at: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
